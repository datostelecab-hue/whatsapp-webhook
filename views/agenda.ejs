<div class="max-w-[1600px] mx-auto px-4 py-6">

  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-white">Agenda</h1>
      <p id="resumen" class="text-telecab-muted text-sm">—</p>
    </div>
    <div class="flex items-center gap-3">
      <span id="estado-op" class="text-sm text-telecab-muted"></span>
      <a href="/planificador" class="px-4 py-2 rounded-lg border border-telecab-border text-telecab-text hover:bg-telecab-card transition">
        <i class="fa-solid fa-table-cells mr-1"></i> Planificador
      </a>
      <button id="btn-importar" class="px-4 py-2 rounded-lg border border-telecab-gold/50 text-telecab-gold hover:bg-telecab-gold/10 transition font-medium">
        <i class="fa-solid fa-file-arrow-up mr-1"></i> Importar anexo
      </button>
      <input id="file-anexo" type="file" accept=".xlsx,.xls" class="hidden">
      <button id="btn-nuevo" class="px-4 py-2 rounded-lg bg-telecab-gold hover:bg-telecab-gold-soft text-telecab-dark font-semibold transition">
        <i class="fa-solid fa-user-plus mr-1"></i> Nuevo conductor
      </button>
      <button id="btn-recargar" class="px-4 py-2 rounded-lg border border-telecab-border text-telecab-text hover:bg-telecab-card transition">
        <i class="fa-solid fa-rotate mr-1"></i> Recargar
      </button>
    </div>
  </div>

  <!-- Pestañas -->
  <div class="flex gap-1 mb-5 border-b border-telecab-border">
    <button data-tab="agenda" class="tab px-5 py-2.5 font-medium text-telecab-gold border-b-2 border-telecab-gold">
      Conductores <span id="n-agenda" class="text-xs text-telecab-muted"></span>
    </button>
    <button data-tab="out" class="tab px-5 py-2.5 font-medium text-telecab-muted border-b-2 border-transparent hover:text-telecab-text">
      Archivo <span id="n-out" class="text-xs"></span>
    </button>
  </div>

  <div id="avisos" class="hidden mb-5 rounded-lg border border-amber-600/50 bg-amber-900/20 p-4 text-sm"></div>

  <!-- ══════════ PESTAÑA CONDUCTORES ══════════ -->
  <section id="panel-agenda">
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <input id="f-buscar" type="search" placeholder="Nombre, ID o matrícula…"
             class="flex-1 min-w-[220px] px-3 py-2 rounded-lg bg-telecab-card border border-telecab-border
                    text-telecab-text placeholder:text-telecab-muted focus:outline-none focus:border-telecab-gold">
      <select id="f-estado" class="px-3 py-2 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text">
        <option value="">Todos los estados</option>
      </select>
      <select id="f-turno" class="px-3 py-2 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text">
        <option value="">Ambos turnos</option>
        <option>Día</option>
        <option>Noche</option>
      </select>
      <select id="f-contrato" class="px-3 py-2 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text">
        <option value="">Todos los contratos</option>
      </select>
      <label class="flex items-center gap-2 text-sm text-telecab-text cursor-pointer whitespace-nowrap">
        <input id="f-incompletos" type="checkbox" class="accent-telecab-gold"> Solo con datos incompletos
      </label>
    </div>

    <div id="cargando" class="text-center py-16 text-telecab-muted">
      <i class="fa-solid fa-circle-notch fa-spin text-2xl"></i>
      <p class="mt-3">Leyendo la agenda…</p>
    </div>

    <div class="overflow-x-auto rounded-xl border border-telecab-border">
      <table class="w-full text-sm">
        <thead class="bg-telecab-card text-telecab-muted text-xs uppercase">
          <tr>
            <th class="text-left px-3 py-3">Conductor</th>
            <th class="text-left px-3 py-3">Turno</th>
            <th class="text-left px-3 py-3">Estado</th>
            <th class="text-left px-3 py-3">Coche</th>
            <th class="text-center px-3 py-3" id="cab-dias"></th>
            <th class="text-center px-3 py-3">Libra</th>
            <th class="text-left px-3 py-3">Cobertura</th>
            <th class="text-left px-3 py-3">Datos</th>
            <th class="px-3 py-3"></th>
          </tr>
        </thead>
        <tbody id="tabla-agenda"></tbody>
      </table>
    </div>
    <p id="sin-resultados" class="hidden text-center py-10 text-telecab-muted">Ningún conductor coincide.</p>
  </section>

  <!-- ══════════ PESTAÑA ARCHIVO ══════════ -->
  <section id="panel-out" class="hidden">
    <p class="text-telecab-muted text-sm mb-4">
      Bajas de empresa. Al restaurar, la persona vuelve a la agenda como
      <strong class="text-telecab-text">Pendiente Asignar</strong>, sin la matrícula ni los días que tuviera antes.
    </p>
    <div class="overflow-x-auto rounded-xl border border-telecab-border">
      <table class="w-full text-sm">
        <thead class="bg-telecab-card text-telecab-muted text-xs uppercase">
          <tr>
            <th class="text-left px-3 py-3">Conductor</th>
            <th class="text-left px-3 py-3">DNI/NIE</th>
            <th class="text-left px-3 py-3">Turno</th>
            <th class="text-left px-3 py-3">Teléfono</th>
            <th class="text-left px-3 py-3">Fecha de baja</th>
            <th class="text-right px-3 py-3"></th>
          </tr>
        </thead>
        <tbody id="tabla-out"></tbody>
      </table>
    </div>
    <p id="sin-archivo" class="hidden text-center py-10 text-telecab-muted">No hay nadie archivado.</p>
  </section>
</div>

<!-- ══════════ FICHA DEL CONDUCTOR ══════════ -->
<div id="ficha" class="hidden fixed inset-0 z-50 bg-black/60 flex justify-end">
  <div class="w-full max-w-lg h-full bg-telecab-dark border-l border-telecab-border overflow-y-auto">
    <div class="sticky top-0 bg-telecab-dark border-b border-telecab-border px-5 py-4 flex items-center justify-between">
      <h2 id="ficha-titulo" class="text-lg font-bold text-white">Ficha</h2>
      <button id="ficha-cerrar" class="text-telecab-muted hover:text-white text-xl px-2">&times;</button>
    </div>
    <div class="p-5 space-y-4">
      <p id="ficha-error" class="hidden rounded-lg border border-telecab-red/50 bg-telecab-red/10 px-3 py-2 text-sm text-telecab-red"></p>
      <div id="ficha-campos" class="space-y-4"></div>
      <div class="flex gap-3 pt-2">
        <button id="ficha-guardar"
                class="flex-1 px-4 py-2.5 rounded-lg bg-telecab-gold hover:bg-telecab-gold-soft text-telecab-dark font-semibold transition">
          Guardar
        </button>
        <button id="ficha-cancelar"
                class="px-4 py-2.5 rounded-lg border border-telecab-border text-telecab-text hover:bg-telecab-card transition">
          Cancelar
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════ IMPORTAR ANEXO ══════════ -->
<div id="import" class="hidden fixed inset-0 z-50 bg-black/60 flex items-center justify-center p-4">
  <div class="w-full max-w-4xl max-h-[85vh] bg-telecab-dark border border-telecab-border rounded-2xl flex flex-col">
    <div class="flex items-center justify-between px-5 py-4 border-b border-telecab-border">
      <h2 class="text-lg font-bold text-white">Importar anexo de altas</h2>
      <button id="import-cerrar" class="text-telecab-muted hover:text-white text-xl px-2">&times;</button>
    </div>
    <div class="p-5 overflow-y-auto">
      <p id="import-resumen" class="text-sm text-telecab-muted mb-3"></p>
      <div id="import-tabla" class="overflow-x-auto rounded-lg border border-telecab-border"></div>
      <label class="flex items-center gap-2 text-sm text-telecab-text cursor-pointer mt-4">
        <input id="import-geo" type="checkbox" class="accent-telecab-gold" checked>
        Obtener coordenadas de la dirección automáticamente (tarda ~1 s por conductor)
      </label>
      <div id="import-progreso" class="hidden mt-3 text-sm text-telecab-gold"></div>
    </div>
    <div class="flex items-center justify-end gap-3 px-5 py-4 border-t border-telecab-border">
      <button id="import-cancelar" class="px-4 py-2 rounded-lg border border-telecab-border text-telecab-text hover:bg-telecab-card transition">Cancelar</button>
      <button id="import-confirmar" class="px-5 py-2 rounded-lg bg-telecab-gold hover:bg-telecab-gold-soft text-telecab-dark font-semibold transition">
        Crear <span id="import-n"></span> conductores
      </button>
    </div>
  </div>
</div>

<!-- SheetJS para leer el .xlsx en el propio navegador (no se sube el binario) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<!-- Los datos del servidor van en un bloque JSON aparte, no interpolados
     dentro del código: así el editor puede analizarlo como JavaScript normal. -->
<script type="application/json" id="datos-servidor">
  <%- JSON.stringify({ estadosConductor: estadosConductor, diasSem: diasSem, turnos: turnos, contratos: contratos }) %>
</script>

<script>
const CFG = JSON.parse(document.getElementById('datos-servidor').textContent);
const ESTADOS = CFG.estadosConductor;
const DIAS_SEM = CFG.diasSem;
const TURNOS = CFG.turnos;
const CONTRATOS = CFG.contratos;
const CAMPOS_LIB = ['libLun','libMar','libMie','libJue','libVie','libSab','libDom'];

let DATOS = null;
let ARCHIVO = null;

const $ = s => document.querySelector(s);
const esc = s => String(s == null ? '' : s).replace(/[&<>"']/g, c =>
  ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));

const COLOR_ESTADO = {
  'Activo': 'text-telecab-green',
  'Pendiente Asignar': 'text-amber-400',
  'Vacaciones': 'text-sky-400',
  'Baja Médica': 'text-orange-400',
  'Suspendido': 'text-telecab-red',
  'Baja Empresa': 'text-telecab-muted'
};

function aviso(texto, tipo) {
  $('#estado-op').textContent = texto;
  $('#estado-op').className = 'text-sm ' +
    (tipo === 'error' ? 'text-telecab-red' : tipo === 'ok' ? 'text-telecab-green' : 'text-telecab-muted');
}

// ════════ Carga ════════
async function cargar() {
  $('#cargando').classList.remove('hidden');
  try {
    const [rA, rO] = await Promise.all([fetch('/agenda/api/datos'), fetch('/agenda/api/out')]);
    const dA = await rA.json();
    const dO = await rO.json();
    if (!rA.ok) throw new Error(dA.msg);
    if (!rO.ok) throw new Error(dO.msg);
    DATOS = dA;
    ARCHIVO = dO.fichas;
    pintarTodo();
  } catch (e) {
    aviso(e.message, 'error');
  }
  $('#cargando').classList.add('hidden');
}

function pintarTodo() {
  const r = DATOS.resumen;
  $('#resumen').textContent = Object.entries(r.porEstado)
    .map(([e, n]) => `${n} ${e.toLowerCase()}`).join(' · ') || 'sin conductores';
  $('#n-agenda').textContent = `(${r.total})`;
  $('#n-out').textContent = `(${ARCHIVO.length})`;
  $('#cab-dias').innerHTML = DIAS_SEM.map(d => `<span class="inline-block w-10">${esc(d)}</span>`).join('');

  const estados = [...new Set(DATOS.conductores.map(c => c.estadoCalculado))];
  const actual = $('#f-estado').value;
  $('#f-estado').innerHTML = '<option value="">Todos los estados</option>' +
    estados.map(e => `<option ${e === actual ? 'selected' : ''}>${esc(e)}</option>`).join('');

  const conActual = $('#f-contrato').value;
  $('#f-contrato').innerHTML = '<option value="">Todos los contratos</option>' +
    CONTRATOS.map(c => `<option ${c === conActual ? 'selected' : ''}>${esc(c)}</option>`).join('');

  const incompletos = DATOS.conductores.filter(c => c.faltan && c.faltan.length).length;
  $('#resumen').textContent += incompletos ? ` · ${incompletos} con datos incompletos` : '';

  pintarAvisos();
  pintarTabla();
  pintarArchivo();
}

function pintarAvisos() {
  const box = $('#avisos');
  if (!DATOS.avisos.length) { box.classList.add('hidden'); return; }
  box.classList.remove('hidden');
  box.innerHTML = '<strong class="text-amber-400">Revisar:</strong><ul class="mt-2 space-y-1 text-amber-200/90">' +
    DATOS.avisos.map(a => '<li>· ' + esc(a.msg) + '</li>').join('') + '</ul>';
}

function pintarTabla() {
  const texto = $('#f-buscar').value.trim().toLowerCase();
  const estado = $('#f-estado').value;
  const turno = $('#f-turno').value;
  const contrato = $('#f-contrato').value;
  const soloIncompletos = $('#f-incompletos').checked;

  const visibles = DATOS.conductores.filter(c => {
    if (estado && c.estadoCalculado !== estado) return false;
    if (turno && c.turno !== turno) return false;
    if (contrato && c.contrato !== contrato) return false;
    if (soloIncompletos && !(c.faltan && c.faltan.length)) return false;
    if (texto && !`${c.nombre} ${c.id} ${c.dni} ${c.matricula}`.toLowerCase().includes(texto)) return false;
    return true;
  });

  $('#tabla-agenda').innerHTML = visibles.map(c => {
    const dias = c.asignacion.map(v => {
      if (v === 'L') return '<span class="inline-block w-10 text-telecab-muted" title="Libra">L</span>';
      if (!v) return '<span class="inline-block w-10 text-telecab-red" title="Sin asignar">·</span>';
      return `<span class="inline-block w-10 text-telecab-green" title="${esc(v)}">✓</span>`;
    }).join('');

    const opciones = ESTADOS
      .map(e => `<option ${e === c.estadoCalculado ? 'selected' : ''}>${esc(e)}</option>`).join('');

    const faltan = (c.faltan && c.faltan.length)
      ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-400 text-xs"
              title="Falta: ${esc(c.faltan.join(', '))}">
           <i class="fa-solid fa-triangle-exclamation text-[10px]"></i> ${c.faltan.length}
         </span>`
      : '<span class="text-telecab-green text-xs"><i class="fa-solid fa-check"></i></span>';

    return `
    <tr class="border-t border-telecab-border hover:bg-telecab-card/50" data-fila="${c.fila}">
      <td class="px-3 py-2.5">
        <div class="text-telecab-text font-medium">${esc(c.nombre || '(sin nombre)')}</div>
        <div class="text-xs text-telecab-muted">${esc(c.id || 'sin ID de Bolt')}</div>
      </td>
      <td class="px-3 py-2.5 text-telecab-muted">${esc(c.turno || '—')}</td>
      <td class="px-3 py-2.5">
        <select class="px-2 py-1 rounded bg-telecab-dark border border-telecab-border ${COLOR_ESTADO[c.estadoCalculado] || 'text-telecab-text'}"
                data-estado>${opciones}</select>
      </td>
      <td class="px-3 py-2.5 text-telecab-text">${esc(c.matricula || '—')}</td>
      <td class="px-3 py-2.5 text-center whitespace-nowrap">${dias}</td>
      <td class="px-3 py-2.5 text-center whitespace-nowrap">${libranza(c)}</td>
      <td class="px-3 py-2.5 text-xs ${c.diasCubiertos === c.diasLaborables ? 'text-telecab-green' : 'text-amber-400'}">
        ${c.diasCubiertos}/${c.diasLaborables} días
      </td>
      <td class="px-3 py-2.5">${faltan}</td>
      <td class="px-3 py-2.5 text-right">
        <button data-ficha="${c.fila}" title="Ver ficha"
                class="px-2 py-1 rounded text-telecab-muted hover:text-white hover:bg-telecab-card transition">
          <i class="fa-solid fa-pen"></i>
        </button>
      </td>
    </tr>`;
  }).join('');

  $('#sin-resultados').classList.toggle('hidden', visibles.length > 0);
}

function pintarArchivo() {
  $('#tabla-out').innerHTML = ARCHIVO.map(f => `
    <tr class="border-t border-telecab-border hover:bg-telecab-card/50">
      <td class="px-3 py-2.5">
        <div class="text-telecab-text font-medium">${esc(f.nombre || f.id)}</div>
        <div class="text-xs text-telecab-muted">${esc(f.id)}</div>
      </td>
      <td class="px-3 py-2.5 text-telecab-muted">${esc(f.dni || '—')}</td>
      <td class="px-3 py-2.5 text-telecab-muted">${esc(f.turno || '—')}</td>
      <td class="px-3 py-2.5 text-telecab-muted">${esc(f.telefono || '—')}</td>
      <td class="px-3 py-2.5 text-telecab-muted">${esc(f.fechaBaja || '—')}</td>
      <td class="px-3 py-2.5 text-right">
        <button data-restaurar="${esc(f.id)}"
                class="px-3 py-1.5 rounded-lg border border-telecab-border text-telecab-text hover:bg-telecab-card transition text-xs">
          <i class="fa-solid fa-rotate-left mr-1"></i> Restaurar
        </button>
      </td>
    </tr>`).join('');
  $('#sin-archivo').classList.toggle('hidden', ARCHIVO.length > 0);
}

/** Casillas de libranza editables en la propia tabla. */
function libranza(c) {
  return c.libra.map((v, d) => `
    <label class="inline-block w-8" title="${esc(DIAS_SEM[d])}">
      <input type="checkbox" ${v ? 'checked' : ''} class="accent-telecab-gold cursor-pointer"
             data-libranza="${d}">
    </label>`).join('');
}

// ════════ Libranza en línea ════════
$('#tabla-agenda').addEventListener('change', async e => {
  const dia = e.target.dataset.libranza;
  if (dia === undefined) return;

  const fila = Number(e.target.closest('tr').dataset.fila);
  aviso('Guardando libranza…');
  e.target.disabled = true;
  try {
    await guardarCampos(fila, { [CAMPOS_LIB[Number(dia)]]: e.target.checked });
    aviso('Libranza actualizada', 'ok');
    await cargar();
  } catch (err) {
    aviso(err.message, 'error');
    e.target.checked = !e.target.checked;
    e.target.disabled = false;
  }
});

// Edita por número de fila: así funciona también con quien aún no tiene ID.
async function guardarCampos(fila, campos) {
  const r = await fetch('/agenda/api/conductor', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ fila, campos })
  });
  const d = await r.json();
  if (!r.ok) throw new Error(d.msg);
  return d;
}

// ════════ Ficha del conductor ════════
let fichaFila = null;   // null = alta nueva; si no, la fila que se edita

const CAMPOS_FICHA = [
  { g: 'Identificación', campos: [
    { k: 'nombre', etq: 'Nombre y apellidos', tipo: 'texto' },
    { k: 'dni', etq: 'DNI / NIE', tipo: 'texto' },
    { k: 'naf', etq: 'NAF', tipo: 'texto' },
    { k: 'fechaAlta', etq: 'Fecha de alta', tipo: 'texto', ayuda: 'dd/mm/aaaa' }
  ]},
  { g: 'Trabajo', campos: [
    { k: 'turno', etq: 'Turno', tipo: 'lista', valores: TURNOS },
    { k: 'contrato', etq: 'Contrato', tipo: 'lista', valores: CONTRATOS },
    { k: 'recomendador', etq: 'Recomendado por', tipo: 'texto' },
    { k: 'activo', etq: 'Activo', tipo: 'bool' }
  ]},
  { g: 'Contacto', campos: [
    { k: 'telefono', etq: 'Teléfono', tipo: 'texto' },
    { k: 'telEmergencia', etq: 'Teléfono de emergencia', tipo: 'texto' },
    { k: 'direccion', etq: 'Dirección', tipo: 'texto' },
    { k: 'codigoPostal', etq: 'Código postal', tipo: 'texto', ayuda: 'ayuda a localizar mejor las coordenadas', noPersiste: true },
    { k: 'coordenadas', etq: 'Coordenadas', tipo: 'coords' }
  ]},
  { g: 'Otros', campos: [
    { k: 'observaciones', etq: 'Observaciones', tipo: 'area' }
  ]}
];

function abrirFicha(fila) {
  fichaFila = fila;
  const c = fila ? DATOS.conductores.find(x => x.fila === fila) : {};
  $('#ficha-error').classList.add('hidden');
  $('#ficha-titulo').textContent = fila ? (c.nombre || 'Ficha') : 'Nuevo conductor';

  // El ID de Bolt: si ya lo tiene, se muestra fijo (es la referencia del
  // planificador y no se cambia). Si no, se ofrece un campo para completarlo.
  const campoId = (fila && c.idBolt)
    ? `<div class="text-xs text-telecab-muted">ID de Bolt: <span class="text-telecab-text">${esc(c.idBolt)}</span>
         · no se puede cambiar, es la referencia que usa el planificador</div>`
    : `<div>
         <label class="block text-xs text-telecab-muted mb-1">ID de Bolt ${fila ? '(pendiente)' : '(opcional al alta)'}</label>
         <input data-campo="${fila ? 'idBolt' : 'id'}" value="${esc((c && c.idBolt) || '')}"
                class="w-full px-3 py-2 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text">
       </div>`;

  const grupos = CAMPOS_FICHA.map(g => `
    <div>
      <h3 class="text-xs uppercase tracking-wide text-telecab-muted mb-2">${esc(g.g)}</h3>
      <div class="space-y-3">
        ${g.campos.map(f => campoFicha(f, c[f.k])).join('')}
      </div>
    </div>`).join('');

  const libra = `
    <div>
      <h3 class="text-xs uppercase tracking-wide text-telecab-muted mb-2">Días de libranza</h3>
      <div class="flex gap-2">
        ${DIAS_SEM.map((d, i) => `
          <label class="flex-1 text-center cursor-pointer">
            <input type="checkbox" data-campo="${CAMPOS_LIB[i]}" class="accent-telecab-gold"
                   ${(c.libra || [])[i] ? 'checked' : ''}>
            <div class="text-xs text-telecab-muted mt-1">${esc(d)}</div>
          </label>`).join('')}
      </div>
      <p class="text-xs text-telecab-muted mt-2">Los días marcados son los que NO trabaja.</p>
    </div>`;

  // Documentación en Drive: solo para conductores ya existentes (necesitamos
  // una clave estable para su carpeta: ID de Bolt, DNI o, en su defecto, nombre).
  const claveDocs = fila ? (c.idBolt || c.dni || c.nombre || '') : '';
  const docs = fila ? `
    <div id="docs-seccion" data-clave="${esc(claveDocs)}">
      <h3 class="text-xs uppercase tracking-wide text-telecab-muted mb-2">Documentación</h3>
      <div id="docs-aviso" class="hidden rounded-lg border border-telecab-gold/40 bg-telecab-gold/5 px-3 py-2 text-xs text-telecab-gold mb-2"></div>
      <div id="docs-lista" class="space-y-2 mb-3 text-sm text-telecab-muted">Cargando…</div>
      <label id="docs-drop"
             class="flex items-center justify-center gap-2 px-3 py-4 rounded-lg border border-dashed border-telecab-border
                    text-sm text-telecab-muted cursor-pointer hover:border-telecab-gold/50 hover:text-telecab-text transition">
        <i class="fa-solid fa-cloud-arrow-up"></i>
        <span>Subir documentos (DNI, carnet, permiso…)</span>
        <input type="file" id="docs-input" class="hidden" multiple>
      </label>
      <p id="docs-estado" class="hidden text-xs text-telecab-muted mt-1"></p>
    </div>` : '';

  $('#ficha-campos').innerHTML = campoId + grupos + libra + docs;
  $('#ficha').classList.remove('hidden');
  if (fila) initDocumentos();
}

// ---------- Documentación (Google Drive) ----------
async function initDocumentos() {
  const clave = $('#docs-seccion')?.dataset.clave;
  if (!clave) {
    $('#docs-lista').textContent = 'Este conductor no tiene aún un identificador (ID de Bolt / DNI) para guardar documentos.';
    return;
  }
  try {
    const est = await (await fetch('/documentos/api/estado')).json();
    if (!est.configurado) {
      $('#docs-aviso').classList.remove('hidden');
      $('#docs-aviso').innerHTML =
        'El almacén de documentos aún no está configurado. Falta crear una carpeta en Drive, ' +
        'compartirla con la cuenta de servicio y definir <b>DRIVE_DOCS_FOLDER_ID</b> en Render.';
      $('#docs-lista').innerHTML = '';
      $('#docs-drop').classList.add('opacity-50', 'pointer-events-none');
      return;
    }
  } catch (e) { /* si falla el chequeo, se intenta igual */ }

  $('#docs-input').addEventListener('change', e => subirDocumentos(e.target.files, clave));
  await cargarDocumentos(clave);
}

function iconoDoc(mime) {
  if (/pdf/.test(mime)) return 'fa-file-pdf';
  if (/image/.test(mime)) return 'fa-file-image';
  if (/word|document/.test(mime)) return 'fa-file-word';
  if (/sheet|excel/.test(mime)) return 'fa-file-excel';
  return 'fa-file';
}
function tamano(bytes) {
  if (!bytes) return '';
  const kb = bytes / 1024;
  return kb < 1024 ? `${Math.round(kb)} KB` : `${(kb / 1024).toFixed(1)} MB`;
}

async function cargarDocumentos(clave) {
  const cont = $('#docs-lista');
  cont.textContent = 'Cargando…';
  try {
    const r = await (await fetch('/documentos/api/lista?clave=' + encodeURIComponent(clave))).json();
    if (r.status !== 'ok') throw new Error(r.msg);
    if (!r.archivos.length) { cont.innerHTML = '<p class="text-xs text-telecab-muted">Sin documentos todavía.</p>'; return; }
    cont.innerHTML = r.archivos.map(a => `
      <div class="flex items-center gap-2 rounded-lg bg-telecab-card border border-telecab-border px-3 py-2">
        <i class="fa-solid ${iconoDoc(a.mimeType)} text-telecab-gold"></i>
        <a href="${esc(a.webViewLink || '#')}" target="_blank" rel="noopener"
           class="flex-1 text-sm text-telecab-text hover:text-telecab-gold truncate">${esc(a.name)}</a>
        <span class="text-xs text-telecab-muted">${tamano(a.size)}</span>
        <button type="button" data-id="${esc(a.id)}" title="Borrar"
                class="doc-borrar text-telecab-muted hover:text-telecab-red px-1"><i class="fa-solid fa-trash text-xs"></i></button>
      </div>`).join('');
    cont.querySelectorAll('.doc-borrar').forEach(b =>
      b.addEventListener('click', () => borrarDocumento(b.dataset.id, clave)));
  } catch (e) {
    cont.innerHTML = `<p class="text-xs text-telecab-red">Error al cargar: ${esc(e.message)}</p>`;
  }
}

function leerBase64(file) {
  return new Promise((resolve, reject) => {
    const fr = new FileReader();
    fr.onload = () => resolve(String(fr.result).split(',')[1]);   // quita el prefijo data:
    fr.onerror = reject;
    fr.readAsDataURL(file);
  });
}

async function subirDocumentos(fileList, clave) {
  const files = [...(fileList || [])];
  if (!files.length) return;
  const estado = $('#docs-estado');
  estado.classList.remove('hidden');
  let n = 0;
  for (const file of files) {
    n++;
    estado.textContent = `Subiendo ${n}/${files.length}: ${file.name}…`;
    try {
      const base64 = await leerBase64(file);
      const r = await (await fetch('/documentos/api/subir', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ clave, nombre: file.name, mime: file.type, base64 })
      })).json();
      if (r.status !== 'ok') throw new Error(r.msg);
    } catch (e) {
      estado.textContent = `Error con ${file.name}: ${e.message}`;
      await new Promise(res => setTimeout(res, 2500));
    }
  }
  estado.classList.add('hidden');
  $('#docs-input').value = '';
  await cargarDocumentos(clave);
}

async function borrarDocumento(id, clave) {
  if (!confirm('¿Borrar este documento de Drive? No se puede deshacer.')) return;
  try {
    const r = await (await fetch('/documentos/api/archivo/' + id, { method: 'DELETE' })).json();
    if (r.status !== 'ok') throw new Error(r.msg);
    await cargarDocumentos(clave);
  } catch (e) {
    alert('No se pudo borrar: ' + e.message);
  }
}

function campoFicha(f, valor) {
  const base = 'w-full px-3 py-2 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text';
  const ayuda = f.ayuda ? `<p class="text-xs text-telecab-muted mt-1">${esc(f.ayuda)}</p>` : '';

  if (f.tipo === 'bool') {
    return `<label class="flex items-center gap-2 cursor-pointer">
      <input type="checkbox" data-campo="${f.k}" class="accent-telecab-gold" ${valor ? 'checked' : ''}>
      <span class="text-sm text-telecab-text">${esc(f.etq)}</span></label>`;
  }
  if (f.tipo === 'lista') {
    return `<div><label class="block text-xs text-telecab-muted mb-1">${esc(f.etq)}</label>
      <select data-campo="${f.k}" class="${base}">
        <option value=""></option>
        ${f.valores.map(v => `<option ${v === valor ? 'selected' : ''}>${esc(v)}</option>`).join('')}
      </select>${ayuda}</div>`;
  }
  if (f.tipo === 'area') {
    return `<div><label class="block text-xs text-telecab-muted mb-1">${esc(f.etq)}</label>
      <textarea data-campo="${f.k}" rows="3" class="${base}">${esc(valor || '')}</textarea>${ayuda}</div>`;
  }
  if (f.tipo === 'coords') {
    return `<div>
      <label class="block text-xs text-telecab-muted mb-1">${esc(f.etq)}</label>
      <div class="flex gap-2">
        <input data-campo="${f.k}" value="${esc(valor || '')}" placeholder="40.41, -3.70" class="${base}">
        <button type="button" id="btn-geo" title="Obtener de la dirección"
                class="shrink-0 px-3 rounded-lg border border-telecab-gold/50 text-telecab-gold hover:bg-telecab-gold/10 transition">
          <i class="fa-solid fa-location-crosshairs"></i>
        </button>
      </div>
      <p class="text-xs text-telecab-muted mt-1">Se usan para el matching con las bases.</p>
    </div>`;
  }
  return `<div><label class="block text-xs text-telecab-muted mb-1">${esc(f.etq)}</label>
    <input data-campo="${f.k}" value="${esc(valor || '')}" class="${base}">${ayuda}</div>`;
}

function cerrarFicha() {
  $('#ficha').classList.add('hidden');
  fichaFila = null;
}

$('#tabla-agenda').addEventListener('click', e => {
  const btn = e.target.closest('[data-ficha]');
  if (btn) abrirFicha(Number(btn.dataset.ficha));
});
$('#btn-nuevo').addEventListener('click', () => abrirFicha(null));
$('#ficha-cerrar').addEventListener('click', cerrarFicha);
$('#ficha-cancelar').addEventListener('click', cerrarFicha);
// A propósito NO se cierra al hacer clic fuera: se perdían los datos a medio
// rellenar. Solo cierran la X, Cancelar o un guardado correcto.

// Geocodificar desde la ficha: coge la dirección y el CP escritos.
$('#ficha-campos').addEventListener('click', async e => {
  if (!e.target.closest('#btn-geo')) return;
  const dir = $('#ficha-campos').querySelector('[data-campo="direccion"]').value;
  const cp = ($('#ficha-campos').querySelector('[data-campo="codigoPostal"]') || {}).value || '';
  if (!dir.trim()) { aviso('Escribe primero la dirección', 'error'); return; }

  const btn = e.target.closest('#btn-geo');
  btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i>';
  try {
    const r = await fetch('/agenda/api/geocodificar', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ direccion: dir, codigoPostal: cp })
    });
    const d = await r.json();
    if (!r.ok) throw new Error(d.msg);
    if (!d.encontrado) { aviso('No se encontró la dirección', 'error'); }
    else {
      $('#ficha-campos').querySelector('[data-campo="coordenadas"]').value = d.coordenadas;
      aviso(`Coordenadas obtenidas (${d.precision})`, 'ok');
    }
  } catch (err) { aviso(err.message, 'error'); }
  btn.innerHTML = '<i class="fa-solid fa-location-crosshairs"></i>';
});

$('#ficha-guardar').addEventListener('click', async () => {
  const btn = $('#ficha-guardar');
  const err = $('#ficha-error');
  err.classList.add('hidden');

  const campos = {};
  $('#ficha-campos').querySelectorAll('[data-campo]').forEach(el => {
    campos[el.dataset.campo] = el.type === 'checkbox' ? el.checked : el.value;
  });
  delete campos.codigoPostal;   // solo sirve para geocodificar, no se guarda

  btn.disabled = true;
  btn.textContent = 'Guardando…';
  try {
    if (fichaFila) {
      delete campos.id;
      await guardarCampos(fichaFila, campos);
      aviso('Conductor actualizado', 'ok');
    } else {
      const r = await fetch('/agenda/api/conductor', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(campos)
      });
      const d = await r.json();
      if (!r.ok) throw new Error(d.msg);
      aviso(`${d.nombre} dado de alta`, 'ok');
    }
    cerrarFicha();
    await cargar();
  } catch (e) {
    err.textContent = e.message;
    err.classList.remove('hidden');
  }
  btn.disabled = false;
  btn.textContent = 'Guardar';
});

