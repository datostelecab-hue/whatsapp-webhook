<div class="max-w-[1600px] mx-auto px-4 py-6">

  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-white">Matching</h1>
      <p id="resumen" class="text-telecab-muted text-sm">—</p>
    </div>
    <button id="btn-recargar" class="px-4 py-2 rounded-lg border border-telecab-border text-telecab-text hover:bg-telecab-card transition">
      <i class="fa-solid fa-rotate mr-1"></i> Recargar
    </button>
  </div>

  <div id="cargando" class="text-center py-16 text-telecab-muted">
    <i class="fa-solid fa-circle-notch fa-spin text-2xl"></i>
    <p class="mt-3">Calculando…</p>
  </div>

  <!-- ══ Dónde falta gente ══ -->
  <h2 class="text-sm uppercase tracking-wide text-telecab-muted mb-3">Dónde falta gente</h2>
  <div id="zonas" class="grid gap-3 mb-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"></div>

  <!-- ══ Sugerencias ══ -->
  <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
    <h2 class="text-sm uppercase tracking-wide text-telecab-muted">Quién está libre y dónde encaja</h2>
    <div class="flex items-center gap-3">
      <input id="f-buscar" type="search" placeholder="Nombre o ID…"
             class="px-3 py-1.5 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text
                    placeholder:text-telecab-muted text-sm focus:outline-none focus:border-telecab-red">
      <select id="f-turno" class="px-3 py-1.5 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text text-sm">
        <option value="">Ambos turnos</option>
        <option>Día</option>
        <option>Noche</option>
      </select>
      <label class="flex items-center gap-2 text-sm text-telecab-text cursor-pointer">
        <input id="f-encajan" type="checkbox" class="accent-telecab-red" checked> Solo los que encajan
      </label>
    </div>
  </div>

  <div id="sugerencias" class="grid gap-3 lg:grid-cols-2"></div>
  <p id="sin-resultados" class="hidden text-center py-10 text-telecab-muted">Nadie coincide con el filtro.</p>
</div>

<script>
let DATOS = null;
const $ = s => document.querySelector(s);
const esc = s => String(s == null ? '' : s).replace(/[&<>"']/g, c =>
  ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));

async function cargar() {
  $('#cargando').classList.remove('hidden');
  try {
    const r = await fetch('/matching/api/datos');
    const d = await r.json();
    if (!r.ok) throw new Error(d.msg);
    DATOS = d;
    pintar();
  } catch (e) {
    $('#cargando').innerHTML = '<p class="text-telecab-red">' + esc(e.message) + '</p>';
    return;
  }
  $('#cargando').classList.add('hidden');
}

function pintar() {
  const encajan = DATOS.sugerencias.filter(s => s.mejor).length;
  const sinCoords = DATOS.sugerencias.filter(s => s.sinCoordenadas).length;
  $('#resumen').textContent =
    `${DATOS.sugerencias.length} pendientes · ${encajan} con zona compatible` +
    (sinCoords ? ` · ${sinCoords} sin coordenadas` : '');

  const pill = (etq, n) => n > 0
    ? `<span class="inline-block px-2 py-0.5 rounded bg-telecab-red/15 text-telecab-red text-xs mr-1.5 mb-1">${n} ${etq}</span>`
    : '';

  $('#zonas').innerHTML = (DATOS.demandaPorZona || [])
    .filter(z => z.totalFaltan > 0)
    .map(z => `
      <div class="rounded-lg bg-telecab-card border border-telecab-red/40 p-4">
        <div class="flex items-baseline justify-between mb-2">
          <span class="font-semibold text-telecab-text">${esc(z.zona)}</span>
          <span class="text-xs text-telecab-muted">${z.coches} coches</span>
        </div>
        <div class="flex flex-wrap">
          ${pill('fijo día', z.fijosDia)}${pill('fijo noche', z.fijosNoche)}
          ${pill('CT día', z.ctDia)}${pill('CT noche', z.ctNoche)}
        </div>
      </div>`).join('') ||
    '<p class="text-telecab-green col-span-full"><i class="fa-solid fa-check mr-1"></i> Todas las zonas con la plantilla completa.</p>';

  pintarSugerencias();
}

function pintarSugerencias() {
  const texto = $('#f-buscar').value.trim().toLowerCase();
  const turno = $('#f-turno').value;
  const soloEncajan = $('#f-encajan').checked;

  const visibles = DATOS.sugerencias.filter(s => {
    if (turno && s.turno !== turno) return false;
    if (soloEncajan && !s.mejor) return false;
    if (texto && !`${s.nombre} ${s.id}`.toLowerCase().includes(texto)) return false;
    return true;
  });

  $('#sugerencias').innerHTML = visibles.map(s => {
    let cuerpo;
    if (s.sinCoordenadas) {
      cuerpo = `<p class="text-sm text-amber-400">
        <i class="fa-solid fa-location-crosshairs mr-1"></i>
        Sin coordenadas en la agenda: no se puede calcular la distancia.
      </p>`;
    } else if (!s.opciones.length) {
      cuerpo = `<p class="text-sm text-telecab-muted">
        No hay plazas libres de ${esc(s.turno.toLowerCase())} en ninguna zona.
      </p>`;
    } else {
      cuerpo = `<div class="space-y-1.5">` + s.opciones.slice(0, 4).map((o, i) => `
        <div class="flex items-center justify-between text-sm ${i === 0 ? 'text-telecab-text' : 'text-telecab-muted'}">
          <span>
            ${i === 0 ? '<i class="fa-solid fa-star text-telecab-red mr-1 text-xs"></i>' : '<span class="inline-block w-4"></span>'}
            ${esc(o.zona)}
          </span>
          <span>${o.km} km · ${o.plazasLibres} plaza${o.plazasLibres === 1 ? '' : 's'}</span>
        </div>`).join('') + `</div>`;
    }

    return `
    <div class="rounded-xl bg-telecab-card border ${s.mejor ? 'border-telecab-border' : 'border-amber-600/40'} p-4">
      <div class="flex items-start justify-between gap-3 mb-3">
        <div>
          <div class="text-telecab-text font-medium">${esc(s.nombre || s.id)}</div>
          <div class="text-xs text-telecab-muted">
            ${esc(s.id)} · ${esc(s.turno || 'sin turno')}${s.contrato ? ' · ' + esc(s.contrato) : ''}
          </div>
        </div>
        <span class="shrink-0 px-2 py-0.5 rounded bg-amber-500/15 text-amber-400 text-xs">
          ${s.diasLibres} día${s.diasLibres === 1 ? '' : 's'} libre${s.diasLibres === 1 ? '' : 's'}
        </span>
      </div>
      ${cuerpo}
      ${s.telefono ? `<div class="mt-3 pt-3 border-t border-telecab-border text-xs text-telecab-muted">
        <i class="fa-solid fa-phone mr-1"></i>${esc(s.telefono)}</div>` : ''}
    </div>`;
  }).join('');

  $('#sin-resultados').classList.toggle('hidden', visibles.length > 0);
}

['#f-buscar', '#f-turno', '#f-encajan'].forEach(s => $(s).addEventListener('input', pintarSugerencias));
$('#btn-recargar').addEventListener('click', cargar);
cargar();
</script>
