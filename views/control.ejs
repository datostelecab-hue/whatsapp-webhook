<div class="max-w-7xl mx-auto px-4 py-6">

  <div class="flex flex-wrap items-end justify-between gap-3 mb-5">
    <div>
      <h1 class="text-2xl font-bold text-telecab-text">Control de tráfico</h1>
      <p id="subtitulo" class="text-sm text-telecab-muted mt-1">Cargando…</p>
    </div>
    <div class="flex items-center gap-3">
      <span id="reloj" class="text-sm text-telecab-muted"></span>
      <button id="btn-exportar" class="px-4 py-2 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text text-sm hover:border-telecab-gold">
        <i class="fa-solid fa-file-excel mr-1"></i> Exportar
      </button>
      <button id="btn-refrescar" class="px-4 py-2 rounded-lg bg-telecab-gold/10 text-telecab-gold text-sm font-medium hover:bg-telecab-gold/20">
        <i class="fa-solid fa-rotate mr-1"></i> Refrescar
      </button>
    </div>
  </div>

  <div id="aviso-stale" class="hidden mb-5 rounded-lg border border-amber-600/50 bg-amber-900/20 p-3 text-sm text-amber-200"></div>

  <div id="resumen" class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4"></div>
  <div id="sumatoria" class="grid grid-cols-3 gap-3 mb-6"></div>

  <div class="flex gap-1 mb-4 border-b border-telecab-border">
    <button data-vista="hoy" class="vtab px-5 py-2.5 font-medium text-telecab-gold border-b-2 border-telecab-gold">Hoy</button>
    <button data-vista="ayer" class="vtab px-5 py-2.5 font-medium text-telecab-muted border-b-2 border-transparent hover:text-telecab-text">Ayer</button>
    <button data-vista="enviar" class="vtab px-5 py-2.5 font-medium text-telecab-muted border-b-2 border-transparent hover:text-telecab-text">
      <i class="fa-brands fa-whatsapp mr-1"></i> Enviar WhatsApps
    </button>
  </div>

  <div id="barra-filtros" class="flex flex-wrap items-center gap-3 mb-4">
    <input id="f-buscar" type="search" placeholder="Nombre o matrícula…"
           class="flex-1 min-w-[200px] px-3 py-2 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text placeholder:text-telecab-muted focus:outline-none focus:border-telecab-gold">
    <select id="f-turno" class="px-3 py-2 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text">
      <option value="">Ambos turnos</option>
      <option value="Día">Solo Día</option>
      <option value="Noche">Solo Noche</option>
    </select>
    <select id="f-orden" class="px-3 py-2 rounded-lg bg-telecab-card border border-telecab-border text-telecab-text">
      <option value="horas_desc">Horas: mayor a menor</option>
      <option value="horas_asc">Horas: menor a mayor</option>
      <option value="nombre">Nombre (A-Z)</option>
    </select>
    <label class="flex items-center gap-2 text-sm text-telecab-text cursor-pointer whitespace-nowrap">
      <input id="f-problemas" type="checkbox" class="accent-telecab-gold"> Solo los que faltan
    </label>
  </div>

  <div id="cargando" class="text-center py-16 text-telecab-muted">
    <i class="fa-solid fa-circle-notch fa-spin text-2xl"></i>
    <p class="mt-3">Leyendo el tablero…</p>
  </div>

  <div id="secciones" class="space-y-8"></div>
</div>

<script>
const $ = s => document.querySelector(s);
const esc = s => (s ?? '').toString().replace(/[&<>"]/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c]));
const escAttr = s => (s ?? '').toString().replace(/"/g, '&quot;').replace(/</g, '&lt;');
const limpiarTel = t => (t ?? '').toString().replace(/[\s+\-()]/g, '');
let DATOS = null;
let VISTA = 'hoy';

const BADGE = {
  trabajando: { txt: 'Trabajando', cls: 'bg-green-500/15 text-green-400' },
  no_salido:  { txt: 'No ha salido', cls: 'bg-red-500/15 text-red-400' },
  libranza:   { txt: 'Libranza', cls: 'bg-indigo-500/15 text-indigo-300' },
  no_tocaba:  { txt: 'No le tocaba', cls: 'bg-telecab-card2 text-telecab-muted' }
};

async function cargar() {
  $('#cargando').classList.remove('hidden');
  try {
    const r = await fetch('/control/api/datos');
    const d = await r.json();
    if (!r.ok || d.status !== 'ok') throw new Error(d.msg || 'error');
    DATOS = d;
    pintar();
  } catch (e) {
    $('#subtitulo').textContent = 'Error: ' + e.message;
  }
  $('#cargando').classList.add('hidden');
}

function pintar() {
  const esEnviar = VISTA === 'enviar';
  // El tablero (resumen, sumatoria, filtros, exportar) solo en Hoy/Ayer.
  ['#resumen', '#sumatoria', '#barra-filtros', '#btn-exportar'].forEach(sel =>
    $(sel).classList.toggle('hidden', esEnviar));

  $('#subtitulo').textContent = esEnviar
    ? 'Avisar a los que no han salido hoy'
    : (VISTA === 'hoy' ? `${DATOS.diaSemana} ${DATOS.fecha}` : `Ayer · ${DATOS.diaSemanaAyer}`);
  $('#reloj').textContent = 'Actualizado ' + new Date().toLocaleTimeString('es-ES');

  const stale = $('#aviso-stale');
  if (!DATOS.horasVigentes) {
    stale.classList.remove('hidden');
    stale.textContent = `⚠️ Datos_API es de ${DATOS.mesDatos || 'otro mes'}, no del mes actual: las horas pueden no estar al día.`;
  } else stale.classList.add('hidden');

  if (esEnviar) { pintarEnviar(); return; }
  pintarResumen();
  pintarSumatoria();
  pintarSecciones();
}

function pintarResumen() {
  const r = DATOS.resumen[VISTA];
  const verbo = VISTA === 'hoy' ? 'han salido' : 'trabajaron';
  const falta = VISTA === 'hoy' ? 'sin salir' : 'no trabajaron';
  $('#resumen').innerHTML = ['Día', 'Noche'].map(t => `
    <div class="rounded-xl border border-telecab-border bg-telecab-card p-4">
      <div class="text-xs uppercase text-telecab-muted mb-1">${t}</div>
      <div class="text-2xl font-bold text-telecab-text">${r[t].trabajaron}<span class="text-telecab-muted text-base font-normal">/${r[t].esperados}</span></div>
      <div class="text-xs text-telecab-muted mt-1">${verbo} · <span class="text-red-400">${r[t].noTrabajaron} ${falta}</span> · ${r[t].libranza} libran</div>
    </div>`).join('') + `
    <div class="rounded-xl border border-telecab-border bg-telecab-card p-4 col-span-2 flex items-center justify-center text-center">
      <div><div class="text-3xl font-bold text-red-400">${r['Día'].noTrabajaron + r['Noche'].noTrabajaron}</div>
      <div class="text-xs text-telecab-muted mt-1">${VISTA === 'hoy' ? 'sin salir en total' : 'no trabajaron en total'}</div></div>
    </div>`;
}

function pintarSumatoria() {
  const r = DATOS.resumen[VISTA];
  const etiqueta = VISTA === 'hoy' ? 'hoy' : 'ayer';
  const card = (titulo, horas, resaltar) => `
    <div class="rounded-xl border ${resaltar ? 'border-telecab-gold/40 bg-telecab-gold/5' : 'border-telecab-border bg-telecab-card'} p-4 text-center">
      <div class="text-xs uppercase text-telecab-muted mb-1">${titulo}</div>
      <div class="text-2xl font-bold ${resaltar ? 'text-telecab-gold' : 'text-telecab-text'}">${horas.toFixed(1)} <span class="text-base font-normal text-telecab-muted">h</span></div>
    </div>`;
  $('#sumatoria').innerHTML =
    card(`Horas Día (${etiqueta})`, r['Día'].horas, false) +
    card(`Horas Noche (${etiqueta})`, r['Noche'].horas, false) +
    card(`Total ${etiqueta}`, r.horasTotal, true);
}

function filtrar(lista) {
  const texto = $('#f-buscar').value.trim().toLowerCase();
  if (!texto) return lista;
  return lista.filter(c =>
    (c.nombre || '').toLowerCase().includes(texto) ||
    (c.dia.matricula || '').toLowerCase().includes(texto));
}

function ordenar(lista) {
  const modo = $('#f-orden').value;
  const h = c => (c.dia.horas ?? -1);
  const l = lista.slice();
  if (modo === 'horas_asc') return l.sort((a, b) => h(a) - h(b) || a.nombre.localeCompare(b.nombre));
  if (modo === 'nombre') return l.sort((a, b) => a.nombre.localeCompare(b.nombre));
  return l.sort((a, b) => h(b) - h(a) || a.nombre.localeCompare(b.nombre));
}

function filaHtml(c, mostrarBadge) {
  const h = c.dia.horas;
  const horasTxt = h == null ? '—' : h.toFixed(1) + ' h';
  const horasCls = (h != null && h > 0) ? 'text-telecab-text' : 'text-red-400';
  const alerta = c.enDatos ? '' : ' <span class="text-amber-400 text-xs" title="Sin horas en Datos_API (nombre no cruza)">⚠︎</span>';
  const badge = mostrarBadge
    ? `<td class="px-3 py-2"><span class="px-2 py-0.5 rounded-full text-xs ${BADGE[c.dia.estadoControl].cls}">${BADGE[c.dia.estadoControl].txt}</span></td>`
    : '';
  return `<tr class="border-t border-telecab-border">
    <td class="px-3 py-2 text-telecab-text">${esc(c.nombre)}${alerta}</td>
    <td class="px-3 py-2 text-telecab-muted">${esc(c.dia.matricula || (c.dia.libra ? 'Libra' : '—'))}</td>
    <td class="px-3 py-2 text-right font-semibold ${horasCls}">${horasTxt}</td>
    ${badge}
    <td class="px-3 py-2 text-telecab-muted text-xs">${esc(c.telefono) || '<span class="text-amber-400/70">sin teléfono</span>'}</td>
  </tr>`;
}

function tabla(filas, mostrarBadge, vacio) {
  const cuerpo = filas.length ? filas.map(c => filaHtml(c, mostrarBadge)).join('')
    : `<tr><td colspan="${mostrarBadge ? 5 : 4}" class="px-3 py-6 text-center text-telecab-muted">${vacio}</td></tr>`;
  return `<div class="overflow-x-auto rounded-xl border border-telecab-border">
    <table class="w-full text-sm">
      <thead class="bg-telecab-card text-telecab-muted text-xs uppercase"><tr>
        <th class="text-left px-3 py-3">Conductor</th>
        <th class="text-left px-3 py-3">Matrícula</th>
        <th class="text-right px-3 py-3">Horas</th>
        ${mostrarBadge ? '<th class="text-left px-3 py-3">Estado</th>' : ''}
        <th class="text-left px-3 py-3">Teléfono</th>
      </tr></thead>
      <tbody>${cuerpo}</tbody>
    </table></div>`;
}

function pintarSecciones() {
  const cont = $('#secciones');
  const soloFaltan = $('#f-problemas').checked;
  const turnoF = $('#f-turno').value;
  cont.innerHTML = '';

  if (VISTA === 'ayer' && !DATOS.ayerDisponible) {
    cont.innerHTML = `<p class="text-center py-10 text-telecab-muted">No hay datos de ayer (primer día del mes o Datos_API no vigente).</p>`;
    return;
  }

  const turnos = turnoF ? [turnoF] : ['Día', 'Noche'];
  turnos.forEach(turno => {
    const base = DATOS.conductores
      .filter(c => c.turno === turno)
      .map(c => ({ ...c, dia: VISTA === 'hoy' ? c.hoy : c.ayer }));

    const icono = turno === 'Día' ? '☀️' : '🌙';
    let html = `<section><h2 class="text-lg font-semibold text-telecab-text mb-3">${icono} Turno ${turno}</h2>`;

    if (VISTA === 'hoy') {
      let filas = filtrar(base.filter(c => c.dia.debiaSalir || c.dia.libra));
      if (soloFaltan) filas = filas.filter(c => c.dia.estadoControl === 'no_salido');
      html += tabla(ordenar(filas), true, 'Nadie en este turno.');
    } else {
      const esperados = filtrar(base.filter(c => c.dia.debiaSalir));
      const noTrab = ordenar(esperados.filter(c => !((c.dia.horas ?? 0) > 0)));
      const trab = ordenar(esperados.filter(c => (c.dia.horas ?? 0) > 0));
      html += `<div class="mb-2 text-sm font-medium text-red-400">No trabajaron (${noTrab.length})</div>`;
      html += tabla(noTrab, false, 'Ninguno.');
      if (!soloFaltan) {
        html += `<div class="mt-5 mb-2 text-sm font-medium text-green-400">Trabajaron (${trab.length})</div>`;
        html += tabla(trab, false, 'Ninguno.');
      }
    }
    html += '</section>';
    cont.insertAdjacentHTML('beforeend', html);
  });
}

// ════════ Enviar WhatsApps (solo hoy, los que no han salido) ════════
function pintarEnviar() {
  const cont = $('#secciones');
  const noShow = DATOS.conductores
    .map(c => ({ ...c, dia: c.hoy }))
    .filter(c => c.dia.debiaSalir && c.dia.estadoControl === 'no_salido');

  let html = `<div class="mb-4 flex flex-wrap items-center gap-3">
    <button id="btn-enviar" disabled class="px-4 py-2 rounded-lg bg-green-600/20 text-green-400 font-medium hover:bg-green-600/30 disabled:opacity-40">
      <i class="fa-brands fa-whatsapp mr-1"></i> Enviar WS a seleccionados (<span id="n-sel">0</span>)
    </button>
    <label class="text-sm text-telecab-muted flex items-center gap-2 cursor-pointer">
      <input id="chk-todos" type="checkbox" class="accent-telecab-gold"> Seleccionar todos con teléfono
    </label>
    <span id="envio-estado" class="text-sm text-telecab-muted"></span>
  </div>`;

  ['Día', 'Noche'].forEach(turno => {
    const filas = noShow.filter(c => c.turno === turno);
    const icono = turno === 'Día' ? '☀️' : '🌙';
    html += `<section class="mb-6"><h2 class="text-lg font-semibold text-telecab-text mb-3">${icono} ${turno} — no han salido (${filas.length})</h2>
      <div class="overflow-x-auto rounded-xl border border-telecab-border"><table class="w-full text-sm">
        <thead class="bg-telecab-card text-telecab-muted text-xs uppercase"><tr>
          <th class="px-3 py-3 w-10"></th><th class="text-left px-3 py-3">Conductor</th>
          <th class="text-left px-3 py-3">Matrícula</th><th class="text-left px-3 py-3">Teléfono</th></tr></thead><tbody>`;
    html += filas.length ? filas.map(c => {
      const tel = limpiarTel(c.telefono);
      const sinTel = !tel;
      return `<tr class="border-t border-telecab-border">
        <td class="px-3 py-2"><input type="checkbox" class="chk-ws accent-telecab-gold" ${sinTel ? 'disabled' : ''}
             data-nombre="${escAttr(c.nombre)}" data-tel="${escAttr(tel)}"></td>
        <td class="px-3 py-2 text-telecab-text">${esc(c.nombre)}</td>
        <td class="px-3 py-2 text-telecab-muted">${esc(c.dia.matricula || '—')}</td>
        <td class="px-3 py-2 text-telecab-muted text-xs">${sinTel ? '<span class="text-amber-400">sin teléfono</span>' : esc(c.telefono)}</td></tr>`;
    }).join('') : `<tr><td colspan="4" class="px-3 py-6 text-center text-telecab-muted">Nadie sin salir en este turno.</td></tr>`;
    html += `</tbody></table></div></section>`;
  });

  cont.innerHTML = html;

  const conteo = () => {
    const n = document.querySelectorAll('.chk-ws:checked').length;
    $('#n-sel').textContent = n;
    $('#btn-enviar').disabled = n === 0;
  };
  document.querySelectorAll('.chk-ws').forEach(ch => ch.addEventListener('change', conteo));
  $('#chk-todos').addEventListener('change', e => {
    document.querySelectorAll('.chk-ws:not([disabled])').forEach(ch => { ch.checked = e.target.checked; });
    conteo();
  });
  $('#btn-enviar').addEventListener('click', enviarSeleccionados);
}

async function enviarSeleccionados() {
  const sel = [...document.querySelectorAll('.chk-ws:checked')]
    .map(ch => ({ nombre: ch.dataset.nombre, telefono: ch.dataset.tel }));
  if (!sel.length) return;
  if (!confirm(`¿Enviar la plantilla "atencion_hora" a ${sel.length} conductor(es)?`)) return;

  $('#btn-enviar').disabled = true;
  $('#envio-estado').textContent = 'Enviando…';
  try {
    const r = await fetch('/control/enviar-ws', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ destinatarios: sel })
    });
    const d = await r.json();
    if (!r.ok || d.status !== 'ok') throw new Error(d.msg || 'error');
    $('#envio-estado').innerHTML = `✅ Enviados ${d.enviados}/${sel.length}` +
      (d.fallidos ? ` · <span class="text-red-400">${d.fallidos} fallaron</span>` : '');
  } catch (e) {
    $('#envio-estado').innerHTML = `<span class="text-red-400">Error: ${esc(e.message)}</span>`;
  }
  $('#btn-enviar').disabled = false;
}

// ════════ Exportar a Excel (CSV) ════════
function exportarExcel() {
  const dia = VISTA === 'ayer' ? 'ayer' : 'hoy';
  const rows = [['Turno', 'Conductor', 'Matrícula', 'Horas', 'Estado', 'Teléfono']];
  ['Día', 'Noche'].forEach(turno => {
    DATOS.conductores.filter(c => c.turno === turno).forEach(c => {
      const d = dia === 'hoy' ? c.hoy : c.ayer;
      if (!d.debiaSalir && !d.libra) return;
      const horas = d.horas == null ? '' : d.horas.toFixed(1).replace('.', ',');
      const estado = d.libra ? 'Libranza' : ((d.horas ?? 0) > 0 ? 'Trabajó' : 'No trabajó');
      rows.push([turno, c.nombre, d.matricula || (d.libra ? 'Libra' : ''), horas, estado, c.telefono || '']);
    });
  });
  const csv = rows.map(r => r.map(v => {
    const s = (v ?? '').toString();
    return /[";\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
  }).join(';')).join('\r\n');
  const blob = new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8;' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `control_${dia}_${(DATOS.fecha || '').replace(/\//g, '-')}.csv`;
  a.click();
  URL.revokeObjectURL(a.href);
}

document.querySelectorAll('.vtab').forEach(t => t.addEventListener('click', () => {
  document.querySelectorAll('.vtab').forEach(x => {
    x.className = 'vtab px-5 py-2.5 font-medium border-b-2 ' +
      (x === t ? 'text-telecab-gold border-telecab-gold' : 'text-telecab-muted border-transparent hover:text-telecab-text');
  });
  VISTA = t.dataset.vista;
  pintar();
}));

$('#btn-refrescar').addEventListener('click', cargar);
$('#btn-exportar').addEventListener('click', exportarExcel);
$('#f-buscar').addEventListener('input', pintarSecciones);
$('#f-problemas').addEventListener('change', pintarSecciones);
$('#f-turno').addEventListener('change', pintarSecciones);
$('#f-orden').addEventListener('change', pintarSecciones);

cargar();
setInterval(cargar, 5 * 60 * 1000);
</script>
