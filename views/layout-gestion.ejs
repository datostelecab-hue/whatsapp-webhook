<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Telecab · <%= titulo || 'Gestión' %></title>
  <link rel="icon" type="image/png" href="/assets/logo-64.png">

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
          colors: {
            'telecab': {
              // Superficies: negro cálido, como el fondo del logo
              'dark': '#0e1116', 'card': '#171b22', 'card2': '#1e232c',
              'border': '#282e39',
              // Acento de marca: el dorado del logo
              'gold': '#e8b84b', 'gold-soft': '#f3d072', 'gold-deep': '#c9962f',
              // Rojo reservado para acciones destructivas / peligro
              'red': '#e5484d', 'red-hover': '#c93b40',
              'green': '#3ecf8e', 'text': '#e6e8ec', 'muted': '#8b93a1'
            }
          },
          boxShadow: {
            'soft': '0 1px 3px rgba(0,0,0,.3), 0 8px 24px -12px rgba(0,0,0,.5)',
            'gold': '0 4px 20px -6px rgba(232,184,75,.35)'
          }
        }
      }
    }
  </script>

  <style>
    :root { color-scheme: dark; }
    body { font-family: 'Inter', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }

    /* Fondo con un halo dorado muy tenue arriba a la izquierda */
    .app-bg {
      background:
        radial-gradient(60rem 40rem at -10% -10%, rgba(232,184,75,.06), transparent 60%),
        radial-gradient(50rem 40rem at 110% 0%, rgba(62,207,142,.04), transparent 55%),
        #0e1116;
    }

    /* Marca del sidebar: anillo dorado con brillo suave */
    .brand-ring {
      background: conic-gradient(from 180deg, #c9962f, #f3d072, #c9962f, #e8b84b, #c9962f);
      padding: 2px; border-radius: 9999px;
      box-shadow: 0 0 24px -6px rgba(232,184,75,.5);
    }
    .gold-text {
      background: linear-gradient(135deg, #f3d072, #c9962f);
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }

    /* Barra dorada del ítem activo del menú */
    .nav-item { position: relative; }
    .nav-item.activo::before {
      content: ''; position: absolute; left: 0; top: 20%; bottom: 20%;
      width: 3px; border-radius: 0 3px 3px 0;
      background: linear-gradient(180deg, #f3d072, #c9962f);
    }

    ::-webkit-scrollbar { width: 7px; height: 7px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #2e3542; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #3a4250; }

    @keyframes fade-in { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
    main > * { animation: fade-in .3s ease; }
  </style>
</head>
<body class="app-bg text-telecab-text min-h-screen">

<div class="flex min-h-screen">

  <!-- ══════════ MENÚ LATERAL ══════════ -->
  <aside id="menu"
         class="fixed lg:sticky top-0 left-0 z-40 h-screen w-64 shrink-0
                bg-telecab-card/80 backdrop-blur-xl border-r border-telecab-border
                flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-300">

    <!-- Marca -->
    <a href="/planificador" class="flex items-center gap-3 px-5 py-5 border-b border-telecab-border/70">
      <span class="brand-ring shrink-0">
        <span class="block w-12 h-12 rounded-full overflow-hidden bg-telecab-dark">
          <!-- Vídeo de marca; si no carga o el navegador lo bloquea, queda el logo debajo -->
          <video class="w-full h-full object-cover" autoplay muted loop playsinline preload="metadata"
                 poster="/assets/logo-128.png"
                 onerror="this.replaceWith(Object.assign(new Image(),{src:'/assets/logo-128.png',className:'w-full h-full object-cover'}))">
            <source src="/assets/telecab.mp4" type="video/mp4">
          </video>
        </span>
      </span>
      <span class="leading-tight">
        <span class="block text-lg font-bold tracking-tight">tele<span class="gold-text">cab</span></span>
        <span class="block text-[11px] text-telecab-muted">Gestión de flota</span>
      </span>
    </a>

    <!-- Navegación -->
    <nav class="flex-1 p-3 space-y-1 overflow-y-auto">
      <%
        const seccionActiva = typeof seccion !== 'undefined' ? seccion : '';
        const enlaces = [
          { href: '/planificador', icono: 'fa-table-cells-large', texto: 'Planificador', id: 'planificador' },
          { href: '/agenda',       icono: 'fa-users',             texto: 'Agenda',       id: 'agenda' },
          { href: '/control',      icono: 'fa-satellite-dish',    texto: 'Control',      id: 'control' },
          { href: '/cobertura',    icono: 'fa-calendar-week',     texto: 'Cobertura',    id: 'cobertura' },
          { href: '/matching',     icono: 'fa-location-dot',      texto: 'Matching',     id: 'matching' },
          { href: '/vehiculos',    icono: 'fa-car-side',          texto: 'Vehículos',    id: 'vehiculos' }
        ];
      %>
      <% enlaces.forEach(function (e) { const on = seccionActiva === e.id; %>
        <a href="<%= e.href %>"
           class="nav-item <%= on ? 'activo' : '' %> flex items-center gap-3 px-3 py-2.5 rounded-xl transition
                  <%= on
                        ? 'bg-telecab-gold/10 text-telecab-gold font-semibold'
                        : 'text-telecab-text hover:bg-telecab-card2' %>">
          <i class="fa-solid <%= e.icono %> w-5 text-center <%= on ? '' : 'text-telecab-muted' %>"></i>
          <span class="text-sm"><%= e.texto %></span>
        </a>
      <% }); %>
    </nav>

    <!-- Pie -->
    <div class="p-3 border-t border-telecab-border/70">
      <a href="/dashboard" class="flex items-center gap-3 px-3 py-2 rounded-xl text-telecab-muted hover:bg-telecab-card2 transition text-sm">
        <i class="fa-solid fa-chart-line w-5 text-center"></i>
        <span>Horas de Bolt</span>
      </a>
      <p class="px-3 pt-3 text-[11px] text-telecab-muted">© <%= new Date().getFullYear() %> Telecab</p>
    </div>
  </aside>

  <div id="menu-fondo" class="hidden fixed inset-0 z-30 bg-black/60 backdrop-blur-sm lg:hidden"></div>

  <!-- ══════════ CONTENIDO ══════════ -->
  <div class="flex-1 min-w-0 flex flex-col">

    <!-- Barra superior -->
    <header class="sticky top-0 z-20 flex items-center gap-3 px-4 lg:px-6 h-14
                   bg-telecab-dark/70 backdrop-blur-lg border-b border-telecab-border">
      <button id="menu-abrir" class="lg:hidden w-9 h-9 rounded-lg hover:bg-telecab-card2 transition">
        <i class="fa-solid fa-bars"></i>
      </button>
      <h1 class="font-semibold text-telecab-text"><%= titulo || 'Gestión' %></h1>
      <span class="ml-auto text-xs text-telecab-muted hidden sm:flex items-center gap-2">
        <i class="far fa-clock"></i>
        <%= new Date().toLocaleString('es-ES', { weekday: 'short', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
      </span>
    </header>

    <main class="flex-1"><%- body %></main>
  </div>
</div>

<script>
  const menu = document.getElementById('menu');
  const fondo = document.getElementById('menu-fondo');
  const abrir = () => { menu.classList.remove('-translate-x-full'); fondo.classList.remove('hidden'); };
  const cerrar = () => { menu.classList.add('-translate-x-full'); fondo.classList.add('hidden'); };
  document.getElementById('menu-abrir').addEventListener('click', abrir);
  fondo.addEventListener('click', cerrar);
  menu.querySelectorAll('a').forEach(a => a.addEventListener('click', cerrar));
</script>

</body>
</html>
